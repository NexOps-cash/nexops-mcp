pragma cashscript ^0.13.0;
contract VestingOwnerCancel(
    pubkey beneficiary,
    pubkey owner,
    int cliffTime,
    bytes payoutLock
) {
    function claim(sig beneficiarySig) {
        require(checkSig(beneficiarySig, beneficiary));
        require(tx.time >= cliffTime);
        require(tx.outputs.length == 1);
        require(tx.outputs[0].lockingBytecode == payoutLock);
        require(tx.outputs[0].value == tx.inputs[this.activeInputIndex].value);
    }

    function cancel(sig ownerSig, int cancelNotBefore) {
        require(checkSig(ownerSig, owner));
        require(tx.time >= cancelNotBefore);
        require(tx.outputs.length == 1);
        require(tx.outputs[0].value == tx.inputs[this.activeInputIndex].value);
    }
}
