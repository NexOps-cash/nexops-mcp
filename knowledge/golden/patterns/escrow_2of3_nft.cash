// ============================================================
// GOLDEN TEMPLATE
// Pattern-ID: escrow_2of3_nft
// Version: 2.0
// Risk-Level: HIGH
// ============================================================

pragma cashscript ^0.13.0;

// @pattern: escrow_2of3_nft
// @invariants: [MULTISIG_2OF3, TIMELOCK_REFUND, NFT_CONTINUITY, VALUE_PRESERVATION, SELF_ANCHOR]
// @allowed_mutation: [CONSTRUCTOR, BUSINESS_LOGIC]
// @forbidden_mutation: [INVARIANT_ANCHOR, VALUE_ANCHOR]

contract Escrow2of3NFT(

    // === MUTABLE_CONSTRUCTOR_START ===
    pubkey buyer,
    pubkey seller,
    pubkey arbiter,
    int refundLocktime
    // === MUTABLE_CONSTRUCTOR_END ===

) {

    // ── Release function (2-of-3 multisig path) ─────────────────────────────
    function release(sig sig1, sig sig2) {

        // ====================================================
        // === INVARIANT_ANCHOR_START =========================
        // ====================================================

        // Enforce minimum output structure (>= 1 allows fee outputs)
        require(tx.outputs.length >= 1);

        // Enforce party distinctness (prevents collusion bypass)
        require(buyer != seller);
        require(buyer != arbiter);
        require(seller != arbiter);

        // 2-of-3 multisig: any two parties must agree
        // Each sig slot corresponds to a specific caller position
        bool caller1IsBuyer   = checkSig(sig1, buyer);
        bool caller1IsSeller  = checkSig(sig1, seller);
        bool caller1IsArbiter = checkSig(sig1, arbiter);
        bool caller2IsBuyer   = checkSig(sig2, buyer);
        bool caller2IsSeller  = checkSig(sig2, seller);
        bool caller2IsArbiter = checkSig(sig2, arbiter);

        bool validPair =
            (caller1IsBuyer   && caller2IsSeller)  ||
            (caller1IsBuyer   && caller2IsArbiter) ||
            (caller1IsSeller  && caller2IsBuyer)   ||
            (caller1IsSeller  && caller2IsArbiter) ||
            (caller1IsArbiter && caller2IsBuyer)   ||
            (caller1IsArbiter && caller2IsSeller);
        require(validPair);

        // NFT continuity: token category must be preserved
        require(
            tx.outputs[0].tokenCategory ==
            tx.inputs[this.activeInputIndex].tokenCategory
        );

        // Token amount preservation (prevents silent token burn)
        require(
            tx.outputs[0].tokenAmount ==
            tx.inputs[this.activeInputIndex].tokenAmount
        );

        // Self-anchor REMOVED: NFT can leave covenant to a destination wallet.
        // The BUSINESS_LOGIC_ZONE is responsible for enforcing the recipient.

        // ====================================================
        // === INVARIANT_ANCHOR_END ===========================
        // ====================================================


        // ====================================================
        // === BUSINESS_LOGIC_ZONE ============================
        // ====================================================

        // This zone is LLM-adaptable. The LLM may implement:
        //   - Output indexing (outputs[0] → seller, outputs[1] → platform fee)
        //   - Fee calculation (e.g. 1% of input value)
        //   - Minimum output count enforcement if fee is required
        //   - Value distribution checks
        //
        // Fee pattern example:
        //   When implementing a percentage-based fee:
        //   - Compute: int fee = (tx.inputs[this.activeInputIndex].value * numerator) / denominator;
        //   - Enforce: require(tx.outputs.length >= 2);
        //   - Enforce: require(tx.outputs[1].value == fee);
        //   - Enforce: require(tx.outputs[1].lockingBytecode == <feeRecipient locking bytecode>);
        //   - Enforce: require(tx.outputs[0].value == tx.inputs[this.activeInputIndex].value - fee);
        //   - Do NOT reference this.activeBytecode in business logic.
        //   - Do NOT modify tokenCategory or tokenAmount checks above.


        // ====================================================
        // === VALUE_ANCHOR ==================================
        // ====================================================
        // VALUE_ANCHOR is delegated to business logic for escrow release.
        // The LLM must enforce value accounting in the business_logic_block above.
        // Minimum guarantee: at least 1 output exists (enforced in invariant anchor).
    }

    // ── Refund function (timelock path: buyer only, after locktime) ──────────
    function refund(sig buyerSig) {

        require(tx.time >= refundLocktime);
        require(checkSig(buyerSig, buyer));

        require(tx.outputs.length == 1);

        // Validate output destination before accessing token properties
        // (prevents implicit_output_ordering attacks)
        require(tx.outputs[0].tokenCategory == tx.inputs[this.activeInputIndex].tokenCategory);
        require(tx.outputs[0].tokenAmount   == tx.inputs[this.activeInputIndex].tokenAmount);
        require(tx.outputs[0].value         == tx.inputs[this.activeInputIndex].value);
    }
}
