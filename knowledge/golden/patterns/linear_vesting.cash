// ============================================================
// GOLDEN TEMPLATE
// Pattern-ID: linear_vesting
// Version: 2.0
// Risk-Level: HIGH
// ============================================================

pragma cashscript ^0.13.0;

// @pattern: linear_vesting
// @invariants: [BENEFICIARY_AUTH, UNLOCK_GATE, REMAINDER_PRESERVATION, OUTPUT_STRUCTURE]
// @allowed_mutation: [CONSTRUCTOR, BUSINESS_LOGIC]
// @forbidden_mutation: [INVARIANT_ANCHOR, VALUE_ANCHOR]

contract LinearVesting(

    // === MUTABLE_CONSTRUCTOR_START ===
    pubkey beneficiary,
    int cliffBlock,
    int endBlock,
    int unlockAmount,
    pubkey feeRecipient
    // === MUTABLE_CONSTRUCTOR_END ===

) {

    // ── Vest function: partial unlock after cliff ────────────────────────────
    function vest(sig beneficiarySig) {

        // ====================================================
        // === INVARIANT_ANCHOR_START =========================
        // ====================================================

        // Cliff must have passed
        require(tx.time >= cliffBlock);

        // Only beneficiary can withdraw
        require(checkSig(beneficiarySig, beneficiary));

        // Strict 3-output structure:
        // [0] beneficiary withdrawal (net)
        // [1] platform fee
        // [2] contract remainder (self-anchor)
        require(tx.outputs.length == 3);

        // Withdrawal cap enforcement
        require(tx.outputs[0].value <= unlockAmount);

        // Fee recipient binding
        require(
            tx.outputs[1].lockingBytecode ==
            new LockingBytecodeP2PKH(hash160(feeRecipient))
        );

        // Self-continuity for remainder
        require(
            tx.outputs[2].lockingBytecode ==
            this.activeBytecode
        );

        // ====================================================
        // === INVARIANT_ANCHOR_END ===========================
        // ====================================================


        // ====================================================
        // === BUSINESS_LOGIC_ZONE ============================
        // ====================================================

        // LLM computes fee here.
        // Must NOT change output structure.
        // Must NOT change self-anchor logic.
        // Must NOT modify unlockAmount cap.


        // ====================================================
        // === VALUE_ANCHOR ==================================
        // ====================================================

        // Exact value conservation:
        require(
            tx.outputs[2].value ==
            tx.inputs[this.activeInputIndex].value
            - tx.outputs[0].value
            - tx.outputs[1].value
        );
    }

    // ── Finalize function: full release after vesting period ends ───────────
    function finalize(sig beneficiarySig) {

        // Vesting period must have fully ended
        require(tx.time >= endBlock);

        // Only beneficiary can finalize
        require(checkSig(beneficiarySig, beneficiary));

        // Single output: all remaining funds to beneficiary
        require(tx.outputs.length == 1);
        require(tx.outputs[0].value == tx.inputs[this.activeInputIndex].value);
    }
}
